# Oracle 数据库连接配置
#
# 复制本文件为 database.yaml 并填写实际连接信息:
#   cp config/database.yaml.example config/database.yaml
#
# JDBC URL 支持两种格式:
#   SID 格式:          jdbc:oracle:thin:@host:port:SID
#   Service Name 格式: jdbc:oracle:thin:@host:port/service_name

oracle:
  jdbc_url: "jdbc:oracle:thin:@your-oracle-host:1521:YOUR_SID"
  user: "your_username"
  password: "your_password"

  # 连接池配置
  pool_min: 2     # 最小连接数
  pool_max: 10    # 最大连接数 (10-20 并发用户建议 10)
