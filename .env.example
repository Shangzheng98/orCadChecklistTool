# AI Provider: "anthropic" or "openai_compatible"
AI_PROVIDER=anthropic

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Internal LLM (OpenAI-compatible API)
OPENAI_BASE_URL=http://192.168.1.100:8000/v1
OPENAI_API_KEY=your-internal-key
OPENAI_MODEL=your-internal-model

# CORS allowed origins (comma-separated, do NOT use "*" with credentials)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
